---
import CardFodaZona from "../CardFodaZona.astro";
import CardProductoEstrategia from "../CardProductoEstrategia.astro";
import CardPasosPresupuesto from "../CardPasosPresupuesto.astro";
---

<section
  id="results-section"
  class="hidden mt-sp-4"
  aria-live="polite"
>
  <div
    class="will-animate flex flex-col sm:flex-row sm:items-center justify-between gap-sp-4 mb-sp-10"
  >
    <div>
      <h2
        data-animate="results-title"
        class="font-display text-[clamp(2.2rem,5vw,3rem)] font-normal mb-sp-1 text-text-primary"
      >
        Tu diagnóstico
      </h2>
      <p
        data-animate="results-subtitle"
        class="font-mono text-[0.8rem] text-text-tertiary tracking-widest uppercase"
      >
        Estrategia generada con IA
      </p>
    </div>
    <div class="flex items-center gap-sp-3">
      <button
        id="download-pdf"
        style="display: none;"
        class="cursor-pointer flex items-center gap-2 px-sp-5 py-sp-3 bg-amber border border-amber rounded-xl text-white font-bold text-sm hover:bg-amber-dim hover:border-amber-dim transition-all shadow-md"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        <span>Descargar PDF</span>
      </button>

      <button
        id="back-to-form"
        class="cursor-pointer flex items-center gap-2 px-sp-5 py-sp-3 bg-white border border-border-default rounded-xl text-text-secondary font-bold text-sm hover:border-amber hover:text-amber transition-all shadow-sm"
      >
        <span>←</span> Nuevo análisis
      </button>
    </div>
  </div>
  <div class="flex flex-col gap-sp-10">
    <CardFodaZona />
    <CardProductoEstrategia />
    <CardPasosPresupuesto />
  </div>
</section>
