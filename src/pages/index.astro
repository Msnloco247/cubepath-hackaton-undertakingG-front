---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Hero from "../components/layout/Hero.astro";
import Footer from "../components/layout/Footer.astro";
import MainForm from "../components/dashboard/MainForm.astro";
import ResultsView from "../components/dashboard/ResultsView.astro";
---

<Layout
  title="EmprendeIA — Analiza tu Emprendimiento con IA"
  description="Responde algunas preguntas sobre tu idea de negocio y obtén un análisis completo con FODA, propuesta de valor y plan de pasos con presupuesto."
>
  <Navbar />

  <main class="max-w-[900px] mx-auto px-sp-6 py-sp-12 pb-sp-20 max-[600px]:px-sp-4 max-[600px]:py-sp-8">
    <MainForm />
    <ResultsView />
  </main>

  <Footer />
</Layout>

<script>
  import { initFormHandler } from "../scripts/formHandler";
  
  // Initialize all dashboard logic
  document.addEventListener('DOMContentLoaded', () => {
    initFormHandler();
  });
</script>

<style is:global>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-4px); }
    40% { transform: translateX(4px); }
    60% { transform: translateX(-4px); }
    80% { transform: translateX(2px); }
  }
  .shake {
    animation: shake 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .hidden {
    display: none !important;
  }

  /* Q-Group state styling with better visibility in light mode */
  .q-group[data-state="error"] textarea,
  .q-group[data-state="error"] input {
    border-color: var(--color-error) !important;
    background-color: var(--color-error-bg) !important;
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-error), transparent 90%) !important;
  }
  .q-group[data-state="valid"] textarea,
  .q-group[data-state="valid"] input {
    border-color: var(--color-success) !important;
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-success), transparent 90%) !important;
  }

  @keyframes shimmer {
    100% { transform: translateX(100%); }
  }
</style>
